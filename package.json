{
  "name": "termhalla",
  "version": "0.8.0",
  "description": "Unified terminals, editor, and explorer with saveable workspaces.",
  "author": "localhostworks",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.e2e.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "package": "electron-vite build && electron-builder --win --publish never",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.9",
    "monaco-editor": "^0.52.2",
    "node-pty": "1.1.0-beta34",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-mosaic-component": "^6.1.1",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "patch-package": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
